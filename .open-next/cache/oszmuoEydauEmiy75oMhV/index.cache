-white rounded-xl p-3 md:p-4 min-w-[70px] md:min-w-[90px] shadow-lg\"><span class=\"text-2xl md:text-4xl font-bold block text-center\">15</span><div class=\"absolute inset-x-0 top-1/2 h-px bg-black/10\"></div></div><span class=\"text-xs md:text-sm font-medium text-gray-600 mt-2\">Horas</span></div><div class=\"flex flex-col items-center\"><div class=\"relative bg-gradient-to-br from-emerald-500 to-emerald-600 text-white rounded-xl p-3 md:p-4 min-w-[70px] md:min-w-[90px] shadow-lg\"><span class=\"text-2xl md:text-4xl font-bold block text-center\">00</span><div class=\"absolute inset-x-0 top-1/2 h-px bg-black/10\"></div></div><span class=\"text-xs md:text-sm font-medium text-gray-600 mt-2\">Minutos</span></div><div class=\"flex flex-col items-center\"><div class=\"relative bg-gradient-to-br from-emerald-500 to-emerald-600 text-white rounded-xl p-3 md:p-4 min-w-[70px] md:min-w-[90px] shadow-lg\"><span class=\"text-2xl md:text-4xl font-bold block text-center\">21</span><div class=\"absolute inset-x-0 top-1/2 h-px bg-black/10\"></div></div><span class=\"text-xs md:text-sm font-medium text-gray-600 mt-2\">Segundos</span></div></div><p class=\"text-sm text-gray-500 mt-4\">8 de Abril de 2026, 5:00 PM</p></div><button class=\"inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed bg-emerald-600 text-white hover:bg-emerald-700 focus:ring-emerald-500 px-6 py-3 text-lg shadow-xl hover:shadow-2xl\">Ver rifas disponibles</button><div class=\"flex flex-wrap justify-center gap-6 mt-12 text-sm text-gray-500\"><div class=\"flex items-center gap-2\"><svg class=\"w-5 h-5 text-emerald-500\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z\" clip-rule=\"evenodd\"></path></svg>100% de los fondos al tratamiento</div><div class=\"flex items-center gap-2\"><svg class=\"w-5 h-5 text-emerald-500\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z\" clip-rule=\"evenodd\"></path></svg>Datos bancarios verificados</div></div></div></section><section class=\"py-16 md:py-24 bg-white\"><div class=\"max-w-5xl mx-auto px-4\"><div class=\"text-center mb-12\"><h2 class=\"text-3xl md:text-4xl font-bold text-gray-900 mb-4\">Sobre la Causa</h2><div class=\"w-24 h-1 bg-emerald-500 mx-auto rounded-full\"></div></div><div class=\"grid md:grid-cols-2 gap-12 items-center\"><div class=\"relative\"><div class=\"relative aspect-[4/5] md:aspect-square rounded-2xl overflow-hidden shadow-2xl\"><img src=\"/images/Felix_Martrinez.jpeg\" alt=\"Felix Octavio Martinez Hernandez\" class=\"w-full h-full object-cover\"/><div class=\"absolute inset-0 ring-4 ring-emerald-500/20 rounded-2xl pointer-events-none\"></div></div><div class=\"absolute -bottom-4 -right-4 bg-emerald-600 text-white px-6 py-3 rounded-xl shadow-lg\"><p class=\"text-lg font-bold\">Necesita tu ayuda</p></div></div><div class=\"space-y-6\"><h3 class=\"text-2xl md:text-3xl font-bold text-gray-900\">Felix Octavio Martinez Hernandez</h3><p class=\"text-lg text-gray-600 leading-relaxed\">Se están llevando a cabo estas 3 rifas con el fin de recaudación fondos para la operación y estudios de Felix Octavio Martinez Hernandez.</p><p class=\"text-lg text-gray-600 leading-relaxed\">Tu participación hace una diferencia real en la vida de Felix y su familia. Gracias por apoyar esta causa.</p><div class=\"grid grid-cols-2 gap-4 pt-4\"><div class=\"bg-emerald-50 rounded-xl p-4 text-center\"><p class=\"text-2xl font-bold text-emerald-600\">3</p><p class=\"text-sm text-gray-600\">Rifas disponibles</p></div><div class=\"bg-emerald-50 rounded-xl p-4 text-center\"><p class=\"text-2xl font-b